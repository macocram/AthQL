# AthQL local configuration
#
# 1. Copy this file:
#      cp config/athql.env.example config/athql.env
#
# 2. Edit config/athql.env with your AWS profile, region, and workgroup.
#
# 3. Start AthQL (auto-loads config/athql.env):
#      ./scripts/dev.sh
#
# config/athql.env is gitignored — safe for machine-specific values.

# --- Required ---------------------------------------------------------------
# AWS profile from ~/.aws/credentials or ~/.aws/config
export ATHQL_AWS_PROFILE=your-aws-profile

# Region where Athena, Glue, and your data live (must match your workgroup)
export ATHQL_AWS_REGION=us-east-1

# Athena workgroup (AWS default is often "primary")
export ATHQL_ATHENA_WORKGROUP=primary

# --- Optional ---------------------------------------------------------------
# S3 path for query results. Usually NOT needed — AthQL auto-detects from:
#   • workgroup ResultConfiguration, or
#   • a recent successful query in that workgroup (same as AWS console).
# Set this only if queries fail with "No Athena query output location found".
# export ATHQL_ATHENA_OUTPUT_LOCATION=s3://your-bucket/athena/queries/

# PyAthena staging dir (rarely needed)
# export ATHQL_S3_STAGING_DIR=s3://your-bucket/staging/

# Max rows in the UI results preview (default: 200)
# export ATHQL_PREVIEW_ROW_LIMIT=200

# Glue metadata cache TTL in seconds (default: 900 = 15 min)
# export ATHQL_METADATA_CACHE_TTL_SECONDS=900
